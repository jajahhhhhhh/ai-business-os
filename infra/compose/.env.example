# Copy to .env and fill. Production .env lives ONLY on the VPS
# (or SOPS-encrypted in repo as infra/compose/.env.enc — see docs/runbooks/deploy.md).

ENV=dev
LOG_LEVEL=INFO
DOMAIN=localhost
PUBLIC_API_URL=https://localhost/api
# prod interim auth (TD-5): 'proxy' trusts keyless requests as the owner —
# ONLY valid with Caddy basic_auth enabled over the whole site (runbook step 7).
# MCP servers/automation still use Bearer keys (python -m src.create_api_key).
AUTH_MODE=proxy

# --- Postgres
POSTGRES_USER=osuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aibos
DATABASE_URL=postgresql+asyncpg://osuser:change-me@postgres:5432/aibos

# --- Redis / Qdrant / Meilisearch / MinIO
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-32chars-min
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=aibos
S3_SECRET_KEY=change-me
S3_BUCKET=aibos

# --- App secrets
API_SECRET_KEY=change-me
GRAFANA_ADMIN_PASSWORD=change-me
GLITCHTIP_SECRET_KEY=change-me

# --- External APIs (leave empty until each integration is enabled)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_PLACES_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- LINE daily snapshot (docs/runbooks/gmail-line-setup.md)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_OWNER_USER_ID=

# --- Gmail bank-alert sync (docs/runbooks/gmail-line-setup.md)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- LLM budgets (USD per day, enforced by orchestrator)
LLM_DAILY_BUDGET_USD=5.00

# --- Knowledge base (M2)
EMBEDDING_MODEL=BAAI/bge-m3
KB_MAX_UPLOAD_MB=25

# --- Lead discovery (M5) — docs/runbooks/lead-sources.md
# Dedicated Fernet key for lead contact encryption (urlsafe base64, 32 bytes).
# Empty = derived from API_SECRET_KEY (works, but rotate-unfriendly; warning logged).
PII_ENCRYPTION_KEY=

# --- MCP servers (scoped key created via the API; see mcp-servers/README.md)
AIBOS_API_URL=http://localhost:8000
AIBOS_API_KEY=
