# Caddy 2 — TLS termination + reverse proxy.
# {$DOMAIN} = localhost in dev (self-signed) or the real domain in prod (auto Let's Encrypt).

{$DOMAIN} {
	encode zstd gzip

	# route{} forces directives to run in written order (Caddy otherwise
	# auto-sorts directives, which would let a terminal handle serve a request
	# before basic_auth / the metrics 403 ran).
	route {
		# Password gate (interim, until Auth.js — TD-5, docs/runbooks/
		# first-deploy.md step 7). MUST stay first inside route{} so it runs
		# before any handler serves content. Activate by uncommenting and
		# setting a real bcrypt hash from `caddy hash-password` (the
		# first-deploy runbook does this automatically):
		# basic_auth {
		# 	owner <bcrypt-hash>
		# }

		# Internal-only: Prometheus scrapes api:8000 on the docker network;
		# the metrics endpoint is never served to the internet. Must precede
		# the /api proxy below.
		@metrics path /api/v1/metrics
		respond @metrics 403

		# API
		handle_path /api/* {
			reverse_proxy api:8000
		}

		# Observability (owner-only; protect further with basic_auth in prod)
		handle_path /grafana/* {
			reverse_proxy grafana:3000
		}
		handle_path /glitchtip/* {
			reverse_proxy glitchtip:8080
		}

		# Dashboard
		handle {
			reverse_proxy web:3000
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
